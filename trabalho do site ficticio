<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Raízes do Cerrado — Arquitetura Sustentável & Bioconstrução</title>
<meta name="description" content="Arquitetura sustentável e bioconstrução em harmonia com o Cerrado. Projetos residenciais e comerciais com terra, madeira certificada e energia solar.">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ccircle cx='32' cy='32' r='30' fill='%2316201A'/%3E%3Cpath d='M16 40c8-18 24-18 32 0' stroke='%23E3A23E' stroke-width='4' fill='none' stroke-linecap='round'/%3E%3Ccircle cx='32' cy='20' r='6' fill='%23C1572D'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@500;600;700;800&family=Source+Serif+4:opsz,wght@8..60,400;8..60,500;8..60,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ============ TOKENS ============ */
:root{
  --ink:#161F19;
  --ink-2:#202E26;
  --canopy:#33493B;
  --clay:#C1572D;
  --clay-dark:#A0451F;
  --ochre:#E3A23E;
  --sand:#F1E9D8;
  --sand-2:#E7DBC3;
  --bone:#FBF7EF;
  --line-dark: rgba(251,247,239,0.16);
  --line-light: rgba(22,31,25,0.14);
  --shadow: 0 18px 40px -20px rgba(22,31,25,0.35);
  --radius: 4px;
  --maxw: 1180px;
  --display: 'Big Shoulders Display', sans-serif;
  --body: 'Source Serif 4', serif;
  --mono: 'JetBrains Mono', monospace;
}
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;background:var(--sand);color:var(--ink);font-family:var(--body);font-size:17px;line-height:1.65;-webkit-font-smoothing:antialiased;}
img,svg{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
h1,h2,h3,h4{font-family:var(--display);font-weight:700;text-transform:uppercase;letter-spacing:0.01em;line-height:1.04;margin:0;}
p{margin:0;}
ul{margin:0;padding:0;list-style:none;}
button{font-family:inherit;cursor:pointer;}
.container{max-width:var(--maxw);margin:0 auto;padding:0 28px;}
.section{padding:clamp(64px,9vw,128px) 0;position:relative;}
.section--dark{background:var(--ink);color:var(--bone);}
.section--canopy{background:var(--canopy);color:var(--bone);}
.eyebrow{font-family:var(--mono);font-size:12.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--clay);display:inline-flex;align-items:center;gap:8px;margin:0 0 16px;}
.section--dark .eyebrow,.section--canopy .eyebrow{color:var(--ochre);}
.eyebrow::before{content:"";width:6px;height:6px;border-radius:50%;background:currentColor;display:inline-block;}
h2.h2{font-size:clamp(34px,4.6vw,56px);max-width:14ch;}
.lede{font-family:var(--body);font-size:clamp(17px,1.6vw,20px);max-width:560px;color:inherit;opacity:0.86;font-style:italic;}
.head-row{display:flex;justify-content:space-between;align-items:flex-end;gap:32px;margin-bottom:48px;flex-wrap:wrap;}
.btn{display:inline-flex;align-items:center;gap:10px;font-family:var(--mono);font-size:13px;letter-spacing:0.06em;text-transform:uppercase;padding:15px 26px;border-radius:2px;border:1.5px solid transparent;transition:transform .18s ease, background .2s ease, color .2s ease, border-color .2s ease;}
.btn-primary{background:var(--clay);color:var(--bone);}
.btn-primary:hover{background:var(--clay-dark);transform:translateY(-2px);}
.btn-secondary{border-color:currentColor;color:var(--ink);}
.section--dark .btn-secondary,.section--canopy .btn-secondary{color:var(--bone);}
.btn-secondary:hover{transform:translateY(-2px);background:rgba(22,31,25,0.06);}
.section--dark .btn-secondary:hover,.section--canopy .btn-secondary:hover{background:rgba(251,247,239,0.1);}
:focus-visible{outline:2.5px solid var(--clay);outline-offset:3px;}

/* ============ NAVBAR ============ */
.navbar{position:sticky;top:0;z-index:100;background:rgba(241,233,216,0.92);backdrop-filter:blur(10px);border-bottom:1px solid var(--line-light);}
.nav-inner{max-width:var(--maxw);margin:0 auto;padding:16px 28px;display:flex;align-items:center;justify-content:space-between;gap:24px;}
.brand{display:flex;align-items:center;gap:10px;font-family:var(--display);font-weight:800;font-size:19px;letter-spacing:0.01em;text-transform:uppercase;white-space:nowrap;}
.brand-mark{width:34px;height:34px;flex:none;}
.nav-links{display:flex;align-items:center;gap:26px;font-family:var(--mono);font-size:12.5px;letter-spacing:0.05em;text-transform:uppercase;}
.nav-links a{position:relative;padding:4px 0;color:var(--ink);opacity:0.78;transition:opacity .2s;}
.nav-links a:hover{opacity:1;}
.nav-links a::after{content:"";position:absolute;left:0;bottom:-2px;height:2px;width:0;background:var(--clay);transition:width .2s ease;}
.nav-links a:hover::after{width:100%;}
.nav-cta{display:flex;align-items:center;gap:14px;}
.nav-cta .btn{padding:11px 20px;}
.hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;padding:8px;}
.hamburger span{width:24px;height:2px;background:var(--ink);display:block;}

/* ============ HERO ============ */
.hero{position:relative;background:var(--ink);color:var(--bone);overflow:hidden;}
.hero-inner{max-width:var(--maxw);margin:0 auto;padding:clamp(90px,14vw,150px) 28px clamp(60px,9vw,110px);position:relative;z-index:2;}
.hero-tag{font-family:var(--mono);font-size:13px;letter-spacing:0.18em;text-transform:uppercase;color:var(--ochre);margin-bottom:22px;display:block;}
.hero h1{font-size:clamp(44px,8vw,96px);max-width:13ch;}
.hero h1 em{font-style:normal;color:var(--ochre);}
.hero .lede{margin-top:26px;color:var(--bone);opacity:0.82;font-size:clamp(17px,1.8vw,21px);max-width:520px;}
.hero-ctas{display:flex;gap:16px;margin-top:42px;flex-wrap:wrap;}
.hero-ctas .btn-secondary{color:var(--bone);}
.hero-scene{position:absolute;inset:0;z-index:1;}
.hero-scene svg{width:100%;height:100%;display:block;}

/* divider waves */
.wave{display:block;width:100%;line-height:0;}
.wave svg{width:100%;height:auto;display:block;}

/* ============ ABOUT ============ */
.about-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:64px;align-items:start;}
.about-history{font-size:18px;}
.about-history p{margin-bottom:18px;}
.pillars{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:8px;}
.pillar{border:1px solid var(--line-light);padding:22px 20px;border-radius:var(--radius);background:var(--bone);}
.pillar h4{font-size:15px;letter-spacing:0.05em;margin-bottom:8px;color:var(--clay);}
.pillar p{font-size:14.5px;opacity:0.82;}
.values-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:26px;}
.value-chip{font-family:var(--mono);font-size:12px;letter-spacing:0.04em;text-transform:uppercase;border:1px solid var(--line-light);padding:8px 14px;border-radius:30px;background:var(--bone);}

/* ============ DIFERENCIAIS ============ */
.diff-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line-dark);border:1px solid var(--line-dark);margin-top:8px;}
.diff-card{background:var(--ink);padding:34px 26px;}
.diff-card .icon{width:34px;height:34px;color:var(--ochre);margin-bottom:18px;}
.diff-card h4{font-size:16px;letter-spacing:0.03em;margin-bottom:10px;}
.diff-card p{font-size:14.5px;opacity:0.78;font-family:var(--body);}

/* ============ SERVICES ============ */
.cards-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;}
.s-card{background:var(--bone);border:1px solid var(--line-light);border-radius:var(--radius);padding:32px 28px;transition:transform .2s ease, box-shadow .2s ease;}
.s-card:hover{transform:translateY(-4px);box-shadow:var(--shadow);}
.s-card .icon{width:38px;height:38px;color:var(--clay);margin-bottom:22px;}
.s-card .tag{font-family:var(--mono);font-size:11.5px;letter-spacing:0.08em;text-transform:uppercase;color:var(--clay);margin-bottom:10px;display:block;}
.s-card h3{font-size:21px;text-transform:none;letter-spacing:0;margin-bottom:10px;font-family:var(--display);}
.s-card p{font-size:15px;opacity:0.78;}

/* ============ NUMEROS ============ */
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:40px;text-align:left;}
.stat .num{font-family:var(--mono);font-size:clamp(40px,5.6vw,64px);color:var(--ochre);line-height:1;font-weight:500;}
.stat .label{font-family:var(--body);font-size:15px;opacity:0.78;margin-top:10px;max-width:18ch;}

/* ============ PROJETOS ============ */
.proj-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;}
.proj-card{border:1px solid var(--line-light);background:var(--bone);border-radius:var(--radius);overflow:hidden;}
.proj-thumb{aspect-ratio:4/3;width:100%;background:var(--sand-2);}
.proj-thumb svg{width:100%;height:100%;}
.proj-body{padding:24px 24px 28px;}
.proj-loc{font-family:var(--mono);font-size:11.5px;letter-spacing:0.06em;text-transform:uppercase;color:var(--clay);}
.proj-body h3{font-family:var(--display);text-transform:none;letter-spacing:0;font-size:21px;margin-top:8px;}
.proj-body p{font-size:14.5px;opacity:0.78;margin-top:8px;}

/* ============ EQUIPE ============ */
.team-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:26px;}
.team-card{text-align:left;}
.avatar{width:100%;aspect-ratio:1;border-radius:var(--radius);background:var(--canopy);margin-bottom:16px;overflow:hidden;}
.avatar svg{width:100%;height:100%;}
.team-card h4{font-family:var(--display);text-transform:none;letter-spacing:0;font-size:18px;}
.team-card .role{font-family:var(--mono);font-size:12px;letter-spacing:0.04em;text-transform:uppercase;color:var(--clay);margin-top:6px;display:block;}
.team-card p.bio{font-size:14px;opacity:0.75;margin-top:10px;}

/* ============ DEPOIMENTOS ============ */
.test-track{display:flex;gap:22px;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:8px;margin-top:8px;scrollbar-width:none;}
.test-track::-webkit-scrollbar{display:none;}
.test-card{scroll-snap-align:start;flex:0 0 min(420px,86vw);background:var(--ink-2);border:1px solid var(--line-dark);border-radius:var(--radius);padding:32px 28px;}
.test-card .stars{color:var(--ochre);font-family:var(--mono);letter-spacing:2px;margin-bottom:16px;font-size:14px;}
.test-card p.quote{font-size:16.5px;line-height:1.6;opacity:0.92;}
.test-card .who{margin-top:20px;display:flex;align-items:center;gap:12px;}
.test-card .who .dot{width:8px;height:8px;border-radius:50%;background:var(--clay);}
.test-card .who b{font-family:var(--display);text-transform:none;letter-spacing:0;font-size:14.5px;}
.test-card .who span{font-family:var(--mono);font-size:11.5px;opacity:0.6;display:block;text-transform:uppercase;letter-spacing:0.04em;}
.carousel-nav{display:flex;gap:10px;margin-top:22px;}
.carousel-nav button{width:42px;height:42px;border:1px solid var(--line-dark);background:transparent;color:var(--bone);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .2s;}
.carousel-nav button:hover{background:rgba(251,247,239,0.08);}

/* ============ GALERIA ============ */
.gal-track{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;}
.gal-item{aspect-ratio:3/4;border-radius:var(--radius);overflow:hidden;background:var(--canopy);position:relative;}
.gal-item:nth-child(2),.gal-item:nth-child(5){aspect-ratio:3/4;}
.gal-item svg{width:100%;height:100%;}
.gal-cap{position:absolute;left:0;bottom:0;right:0;padding:14px 12px;font-family:var(--mono);font-size:11px;letter-spacing:0.04em;text-transform:uppercase;color:var(--bone);background:linear-gradient(to top, rgba(22,31,25,0.85), transparent);}

/* ============ FAQ ============ */
.faq-list{max-width:760px;border-top:1px solid var(--line-light);}
.faq-item{border-bottom:1px solid var(--line-light);}
.faq-q{width:100%;background:none;border:none;text-align:left;padding:24px 4px;display:flex;justify-content:space-between;align-items:center;gap:20px;font-family:var(--display);text-transform:none;letter-spacing:0;font-size:19px;color:var(--ink);}
.faq-q .plus{width:22px;height:22px;flex:none;position:relative;}
.faq-q .plus::before,.faq-q .plus::after{content:"";position:absolute;background:var(--clay);transition:transform .25s ease;}
.faq-q .plus::before{left:0;top:50%;width:100%;height:2px;transform:translateY(-50%);}
.faq-q .plus::after{top:0;left:50%;width:2px;height:100%;transform:translateX(-50%);}
.faq-item[data-open="true"] .plus::after{transform:translateX(-50%) scaleY(0);}
.faq-a{max-height:0;overflow:hidden;transition:max-height .3s ease;}
.faq-a-inner{padding:0 4px 24px;font-size:15.5px;opacity:0.8;max-width:60ch;}

/* ============ BLOG ============ */
.blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px;}
.blog-card{background:var(--ink-2);border:1px solid var(--line-dark);border-radius:var(--radius);overflow:hidden;}
.blog-thumb{aspect-ratio:16/10;background:var(--canopy);}
.blog-thumb svg{width:100%;height:100%;}
.blog-body{padding:22px 22px 26px;}
.blog-date{font-family:var(--mono);font-size:11.5px;letter-spacing:0.06em;text-transform:uppercase;color:var(--ochre);}
.blog-body h3{font-family:var(--display);text-transform:none;letter-spacing:0;font-size:19px;margin-top:10px;line-height:1.25;}
.blog-body p{font-size:14px;opacity:0.72;margin-top:10px;}
.blog-read{font-family:var(--mono);font-size:12px;letter-spacing:0.05em;text-transform:uppercase;color:var(--ochre);margin-top:18px;display:inline-block;border-bottom:1px solid currentColor;}

/* ============ LOCALIZACAO ============ */
.loc-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:0;border:1px solid var(--line-light);border-radius:var(--radius);overflow:hidden;}
.loc-info{background:var(--bone);padding:40px 36px;}
.loc-info h3{font-family:var(--display);text-transform:none;letter-spacing:0;font-size:24px;margin-bottom:18px;}
.loc-row{display:flex;gap:14px;margin-bottom:18px;align-items:flex-start;}
.loc-row .icon{width:20px;height:20px;color:var(--clay);flex:none;margin-top:2px;}
.loc-row span{font-size:15px;opacity:0.85;}
.loc-map iframe{width:100%;height:100%;min-height:380px;border:none;display:block;filter:saturate(0.9) contrast(1.02);}

/* ============ CONTATO ============ */
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-bottom:18px;}
.field{display:flex;flex-direction:column;gap:8px;margin-bottom:18px;}
.field label{font-family:var(--mono);font-size:11.5px;letter-spacing:0.06em;text-transform:uppercase;opacity:0.7;}
.field input,.field select,.field textarea{font-family:var(--body);font-size:15.5px;padding:13px 14px;border:1px solid var(--line-light);border-radius:2px;background:var(--bone);color:var(--ink);}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--clay);}
.field textarea{resize:vertical;min-height:110px;}
.form-msg{margin-top:16px;font-family:var(--mono);font-size:13px;color:var(--canopy);display:none;}
.form-msg.show{display:block;}
.contact-info-list{margin-top:30px;display:flex;flex-direction:column;gap:20px;}
.ci-item{display:flex;gap:14px;}
.ci-item .icon{width:22px;height:22px;color:var(--clay);flex:none;}
.ci-item b{display:block;font-family:var(--display);text-transform:none;letter-spacing:0;font-size:15.5px;}
.ci-item span{font-size:14.5px;opacity:0.78;}
.social-row{display:flex;gap:12px;margin-top:30px;}
.social-row a{width:42px;height:42px;border:1px solid var(--line-light);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .2s, border-color .2s;}
.social-row a:hover{background:var(--ink);border-color:var(--ink);color:var(--bone);}
.social-row svg{width:18px;height:18px;}

/* ============ FOOTER ============ */
footer{background:var(--ink);color:var(--bone);padding:72px 0 0;}
.footer-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;padding-bottom:50px;border-bottom:1px solid var(--line-dark);}
.footer-brand .brand{color:var(--bone);}
.footer-brand p{margin-top:18px;font-size:14.5px;opacity:0.72;max-width:28ch;}
.footer-col h5{font-family:var(--mono);font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:var(--ochre);margin-bottom:18px;}
.footer-col ul{display:flex;flex-direction:column;gap:11px;}
.footer-col a{font-size:14.5px;opacity:0.78;transition:opacity .2s;}
.footer-col a:hover{opacity:1;color:var(--ochre);}
.footer-bottom{padding:26px 0 36px;display:flex;justify-content:space-between;gap:20px;flex-wrap:wrap;font-family:var(--mono);font-size:12px;opacity:0.6;letter-spacing:0.02em;}

/* ============ REVEAL ============ */
.reveal{opacity:0;transform:translateY(18px);transition:opacity .6s ease, transform .6s ease;}
.reveal.in-view{opacity:1;transform:translateY(0);}

@media (prefers-reduced-motion: reduce){
  *{transition:none !important; animation:none !important;}
  .reveal{opacity:1;transform:none;}
}

/* ============ RESPONSIVE ============ */
@media (max-width: 980px){
  .nav-links{display:none;}
  .hamburger{display:flex;}
  .navbar.open .nav-links{display:flex;position:absolute;top:100%;left:0;right:0;background:var(--sand);flex-direction:column;align-items:flex-start;padding:20px 28px 28px;gap:18px;border-bottom:1px solid var(--line-light);}
  .nav-cta .btn-secondary{display:none;}
  .about-grid{grid-template-columns:1fr;gap:40px;}
  .diff-grid{grid-template-columns:repeat(2,1fr);}
  .cards-grid{grid-template-columns:repeat(2,1fr);}
  .stats-grid{grid-template-columns:repeat(2,1fr);gap:32px;}
  .proj-grid{grid-template-columns:repeat(2,1fr);}
  .team-grid{grid-template-columns:repeat(2,1fr);}
  .gal-track{grid-template-columns:repeat(3,1fr);}
  .blog-grid{grid-template-columns:repeat(2,1fr);}
  .loc-grid{grid-template-columns:1fr;}
  .contact-grid{grid-template-columns:1fr;gap:36px;}
  .footer-grid{grid-template-columns:1fr 1fr;}
}
@media (max-width: 620px){
  .diff-grid,.cards-grid,.proj-grid,.team-grid,.blog-grid{grid-template-columns:1fr;}
  .stats-grid{grid-template-columns:1fr 1fr;}
  .gal-track{grid-template-columns:repeat(2,1fr);}
  .form-row{grid-template-columns:1fr;}
  .footer-grid{grid-template-columns:1fr;}
  h2.h2{max-width:100%;}
}
</style>
</head>
<body>

<!-- ============ NAVBAR / HEADER ============ -->
<header class="navbar" id="navbar">
  <div class="nav-inner">
    <a href="#topo" class="brand">
      <svg class="brand-mark" viewBox="0 0 64 64" fill="none">
        <circle cx="32" cy="32" r="30" fill="#161F19"/>
        <path d="M14 42c10-20 26-20 36 0" stroke="#E3A23E" stroke-width="3.5" stroke-linecap="round"/>
        <circle cx="32" cy="19" r="6" fill="#C1572D"/>
      </svg>
      Raízes do Cerrado
    </a>
    <nav class="nav-links" aria-label="Navegação principal">
      <a href="#sobre">Sobre</a>
      <a href="#diferenciais">Diferenciais</a>
      <a href="#servicos">Serviços</a>
      <a href="#projetos">Projetos</a>
      <a href="#galeria">Galeria</a>
      <a href="#faq">FAQ</a>
      <a href="#blog">Blog</a>
    </nav>
    <div class="nav-cta">
      <a href="#localizacao" class="btn btn-secondary">Localização</a>
      <a href="#contato" class="btn btn-primary">Fale Connosco</a>
    </div>
    <button class="hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- ============ HERO ============ -->
<section class="hero" id="topo">
  <div class="hero-scene" aria-hidden="true">
    <svg viewBox="0 0 1200 720" preserveAspectRatio="xMidYMax slice" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="sunGlow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="#F2C572" stop-opacity="0.9"/>
          <stop offset="60%" stop-color="#E3A23E" stop-opacity="0.25"/>
          <stop offset="100%" stop-color="#E3A23E" stop-opacity="0"/>
        </radialGradient>
        <linearGradient id="skyFade" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="#161F19"/>
          <stop offset="100%" stop-color="#2B3B2C"/>
        </linearGradient>
      </defs>
      <rect width="1200" height="720" fill="url(#skyFade)"/>
      <circle cx="860" cy="230" r="160" fill="url(#sunGlow)"/>
